{
  "name": "tce-display",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm nuke:dist && vue-tsc && vite build",
    "lint": "eslint ./src",
    "lint:fix": "pnpm lint --fix",
    "nuke": "pnpm dlx del-cli dist node_modules",
    "nuke:dist": "pnpm dlx del-cli dist",
    "prepublish": "pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tailor-cms/eslint-config": "2.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "tce-manifest": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue-tsc": "^3.2.7",
    "vuetify": "^4.0.6"
  },
  "engines": {
    "node": ">=24"
  },
  "description": "Tailor CMS timeline content element",
  "author": "Studion <info@gostudion.com> (https://github.com/tailor-cms)"
}
