{
  "name": "tce-server",
  "description": "Tailor CMS timeline content element",
  "author": "Studion <info@gostudion.com> (https://github.com/tailor-cms)",
  "type": "module",
  "version": "0.0.1",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch src --watch ../manifest/dist",
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "nuke": "pnpm dlx del-cli dist node_modules",
    "nuke:dist": "pnpm dlx del-cli dist",
    "prepublish": "pnpm build"
  },
  "dependencies": {
    "@tailor-cms/cek-common": "2.0.1",
    "tce-manifest": "workspace:*"
  },
  "devDependencies": {
    "@tailor-cms/eslint-config": "2.0.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "tsdown": {
    "target": "node24",
    "format": [
      "cjs",
      "esm"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
